APP_NAME=WiFi Fall Guard
APP_ENV=dev
HOST=127.0.0.1
PORT=8000
DATABASE_URL=sqlite:///./wifi_fall_guard.db
DETECTOR_MODE=enetfall
ENETFALL_DATA_DIR=data\ENetFall_dataset_trained_networks
ENETFALL_MODEL_PATH=data\ENetFall_dataset_trained_networks\B0(modified)_trained_with_all_data.pth

CSI_FRAME_INTERVAL_MS=100
CSI_SUBCARRIER_COUNT=64
CSI_WINDOW_SIZE=30
DEFAULT_ROOM=bedroom

FALL_CONFIDENCE_THRESHOLD=0.75
HIGH_ENERGY_THRESHOLD=30.0
LOW_ACTIVITY_THRESHOLD=2.0

ENABLE_FAKE_LABEL=True
